# Build artifacts and local dev state — never want these in the image
node_modules
.next
out
build
coverage

# Local secrets — never bake into the image
.env
.env.local
.env*.local
.env.development
.env.test

# Git + IDE noise
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Misc dev-only
README.md
design.md
.eslintcache
*.tsbuildinfo
next-env.d.ts
.vercel

# CI / cloud configs that don't need to be in the image
cloudbuild.yaml
Dockerfile
.dockerignore
